@page "{id:int}"
@model FunerariaWeb.Pages.Cerimonias.ApagarModel
@{ ViewData["Title"] = "Apagar cerimónia"; }

<div class="card" style="max-width:520px;">
    <h1>Apagar cerimónia</h1>
    <p>Tem a certeza que pretende apagar a cerimónia de <strong>@Model.Cerimonia.Cliente?.Nome</strong>
       em @Model.Cerimonia.DataCerimonia.ToString("dd/MM/yyyy HH:mm")?</p>
    <p class="text-muted">Os serviços associados a esta cerimónia serão também removidos.</p>
    <form method="post">
        <input type="hidden" asp-for="Cerimonia.Id" />
        <button type="submit" class="btn-perigo">Sim, apagar</button>
        <a class="btn-secundario" href="/Cerimonias">Cancelar</a>
    </form>
</div>
