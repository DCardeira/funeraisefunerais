@page "{id:int}"
@model FunerariaWeb.Pages.Cerimonias.EditarModel
@{ ViewData["Title"] = "Editar cerimónia"; }

<div class="card" style="max-width:680px;">
    <h1>Editar cerimónia</h1>
    <form method="post">
        <input type="hidden" asp-for="Form.Id" />
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-group">
            <label asp-for="Form.ClienteId"></label>
            <select asp-for="Form.ClienteId" asp-items="Model.OpcoesClientes"></select>
            <span asp-validation-for="Form.ClienteId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Form.DataCerimonia"></label>
            <input asp-for="Form.DataCerimonia" type="datetime-local" />
            <span asp-validation-for="Form.DataCerimonia" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Form.Local"></label>
            <input asp-for="Form.Local" />
            <span asp-validation-for="Form.Local" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Form.Estado"></label>
            <select asp-for="Form.Estado" asp-items="Html.GetEnumSelectList<EstadoCerimonia>()"></select>
        </div>

        <div class="form-group">
            <label asp-for="Form.Observacoes"></label>
            <textarea asp-for="Form.Observacoes" rows="3"></textarea>
        </div>

        <div class="form-group">
            <label>Serviços incluídos</label>
            <table>
                <thead><tr><th></th><th>Serviço</th><th>Preço base</th><th>Quantidade</th></tr></thead>
                <tbody>
                @for (int i = 0; i < Model.Form.ServicosDisponiveis.Count; i++)
                {
                    <tr>
                        <td><input type="checkbox" asp-for="Form.ServicosDisponiveis[i].Selecionado" /></td>
                        <td>
                            @Model.Form.ServicosDisponiveis[i].Nome
                            <input type="hidden" asp-for="Form.ServicosDisponiveis[i].ServicoId" />
                            <input type="hidden" asp-for="Form.ServicosDisponiveis[i].Nome" />
                            <input type="hidden" asp-for="Form.ServicosDisponiveis[i].PrecoBase" />
                        </td>
                        <td>@Model.Form.ServicosDisponiveis[i].PrecoBase.ToString("C")</td>
                        <td style="max-width:90px;"><input type="number" min="1" max="100" asp-for="Form.ServicosDisponiveis[i].Quantidade" /></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <button type="submit" class="btn-primario">Guardar alterações</button>
        <a class="btn-secundario" href="/Cerimonias">Cancelar</a>
    </form>
</div>
