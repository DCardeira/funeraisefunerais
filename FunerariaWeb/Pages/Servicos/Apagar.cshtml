@page "{id:int}"
@model FunerariaWeb.Pages.Servicos.ApagarModel
@{ ViewData["Title"] = "Apagar serviço"; }

<div class="card" style="max-width:520px;">
    <h1>Apagar serviço</h1>
    @if (Model.EmUso)
    {
        <div class="alert alert-erro">
            Este serviço está associado a uma ou mais cerimónias e não pode ser apagado.
        </div>
        <a class="btn-secundario" href="/Servicos">Voltar</a>
    }
    else
    {
        <p>Tem a certeza que pretende apagar <strong>@Model.Servico.Nome</strong>?</p>
        <form method="post">
            <input type="hidden" asp-for="Servico.Id" />
            <button type="submit" class="btn-perigo">Sim, apagar</button>
            <a class="btn-secundario" href="/Servicos">Cancelar</a>
        </form>
    }
</div>
