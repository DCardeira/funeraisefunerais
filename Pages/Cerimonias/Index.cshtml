@page
@model FunerariaWeb.Pages.Cerimonias.IndexModel
@{ ViewData["Title"] = "Cerimónias"; }

<div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;">
        <h1>Cerimónias</h1>
        @if (User.IsInRole(Roles.Administrador))
        {
            <a class="btn-primario" href="/Cerimonias/Criar">+ Nova cerimónia</a>
        }
    </div>

    <table>
        <thead><tr><th>Data</th><th>Cliente</th><th>Local</th><th>Estado</th><th>Total</th>@if (User.IsInRole(Roles.Administrador)){<th></th>}</tr></thead>
        <tbody>
        @foreach (var c in Model.Cerimonias)
        {
            <tr>
                <td>@c.DataCerimonia.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@c.Cliente?.Nome</td>
                <td>@c.Local</td>
                <td><span class="badge badge-@c.Estado.ToString().ToLower()">@c.Estado</span></td>
                <td>@c.Total.ToString("C")</td>
                @if (User.IsInRole(Roles.Administrador))
                {
                    <td>
                        <a href="/Cerimonias/Editar/@c.Id">Editar</a> ·
                        <a href="/Cerimonias/Apagar/@c.Id" style="color:var(--danger);">Apagar</a>
                    </td>
                }
            </tr>
        }
        </tbody>
    </table>
    @if (!Model.Cerimonias.Any())
    {
        <p class="text-muted">Não existem cerimónias para mostrar.</p>
    }
</div>
