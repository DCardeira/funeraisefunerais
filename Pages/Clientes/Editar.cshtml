@page "{id:int}"
@model FunerariaWeb.Pages.Clientes.EditarModel
@{ ViewData["Title"] = "Editar cliente"; }

<div class="card" style="max-width:520px;">
    <h1>Editar cliente</h1>
    <form method="post">
        <input type="hidden" asp-for="Cliente.Id" />
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        <div class="form-group">
            <label asp-for="Cliente.Nome"></label>
            <input asp-for="Cliente.Nome" />
            <span asp-validation-for="Cliente.Nome" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Cliente.Email"></label>
            <input asp-for="Cliente.Email" />
            <span asp-validation-for="Cliente.Email" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Cliente.Telefone"></label>
            <input asp-for="Cliente.Telefone" />
            <span asp-validation-for="Cliente.Telefone" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Cliente.Morada"></label>
            <input asp-for="Cliente.Morada" />
        </div>
        <button type="submit" class="btn-primario">Guardar alterações</button>
        <a class="btn-secundario" href="/Clientes">Cancelar</a>
    </form>
</div>
