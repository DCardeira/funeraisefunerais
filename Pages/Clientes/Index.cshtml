@page
@model FunerariaWeb.Pages.Clientes.IndexModel
@{ ViewData["Title"] = "Clientes"; }

<div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;">
        <h1>Clientes</h1>
        <a class="btn-primario" href="/Clientes/Criar">+ Novo cliente</a>
    </div>

    <table>
        <thead>
            <tr><th>Nome</th><th>Email</th><th>Telefone</th><th>Cerimónias</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var c in Model.Clientes)
        {
            <tr>
                <td>@c.Nome</td>
                <td>@c.Email</td>
                <td>@c.Telefone</td>
                <td>@c.Cerimonias.Count</td>
                <td>
                    <a href="/Clientes/Editar/@c.Id">Editar</a> ·
                    <a href="/Clientes/Apagar/@c.Id" style="color:var(--danger);">Apagar</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
    @if (!Model.Clientes.Any())
    {
        <p class="text-muted">Ainda não existem clientes registados.</p>
    }
</div>
