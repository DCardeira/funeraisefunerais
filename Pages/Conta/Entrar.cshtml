@page
@model FunerariaWeb.Pages.Conta.EntrarModel
@{ ViewData["Title"] = "Entrar"; }

<div class="card" style="max-width:420px;margin:0 auto;">
    <h1>Entrar</h1>
    <p class="text-muted">Contas de demonstração: <br />
        <strong>admin@funeraria.pt</strong> / Admin123! (Administrador)<br />
        <strong>cliente@funeraria.pt</strong> / Cliente123! (Cliente)</p>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        <div class="form-group">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Input.Password">Palavra-passe</label>
            <input asp-for="Input.Password" type="password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <button type="submit" class="btn-primario">Entrar</button>
    </form>
</div>
