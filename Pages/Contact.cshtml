@page
@model funeraisefunerais.Pages.ContactModel
@{
    ViewData["Title"] = "Contactar a Empresa";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h3 mb-3">Contacte a empresa</h1>
                    <p class="text-muted mb-4">Preencha este formulário para pedir informação, apoio ou um contacto prioritário.</p>

                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="alert alert-success" role="alert">@successMessage</div>
                    }

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Input.Nome" class="form-label"></label>
                                <input asp-for="Input.Nome" class="form-control" />
                                <span asp-validation-for="Input.Nome" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Email" class="form-label"></label>
                                <input asp-for="Input.Email" class="form-control" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Telefone" class="form-label"></label>
                                <input asp-for="Input.Telefone" class="form-control" />
                                <span asp-validation-for="Input.Telefone" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Assunto" class="form-label"></label>
                                <input asp-for="Input.Assunto" class="form-control" />
                                <span asp-validation-for="Input.Assunto" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Input.Mensagem" class="form-label"></label>
                                <textarea asp-for="Input.Mensagem" class="form-control" rows="6"></textarea>
                                <span asp-validation-for="Input.Mensagem" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Enviar pedido</button>
                            <a asp-page="Index" class="btn btn-outline-secondary">Voltar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
