@page
@model funeraisefunerais.Pages.ContactRequestsModel
@{
    ViewData["Title"] = "Pedidos de Contacto";
}

<div class="container py-5">
    <h1 class="h3 mb-4">Pedidos de contacto</h1>

    @if (!Model.Pedidos.Any())
    {
        <div class="alert alert-info">Ainda não existem pedidos.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Assunto</th>
                        <th>Data</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in Model.Pedidos)
                    {
                        <tr>
                            <td>@pedido.Nome</td>
                            <td>@pedido.Email</td>
                            <td>@pedido.Assunto</td>
                            <td>@pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(pedido.Respondido ? "Respondido" : "Pendente")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
