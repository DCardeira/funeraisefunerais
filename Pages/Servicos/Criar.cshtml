@page
@model FunerariaWeb.Pages.Servicos.CriarModel
@{ ViewData["Title"] = "Novo serviço"; }

<div class="card" style="max-width:520px;">
    <h1>Novo serviço</h1>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        <div class="form-group">
            <label asp-for="Servico.Nome"></label>
            <input asp-for="Servico.Nome" />
            <span asp-validation-for="Servico.Nome" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Servico.Descricao"></label>
            <textarea asp-for="Servico.Descricao" rows="3"></textarea>
        </div>
        <div class="form-group">
            <label asp-for="Servico.PrecoBase"></label>
            <input asp-for="Servico.PrecoBase" type="number" step="0.01" />
            <span asp-validation-for="Servico.PrecoBase" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Servico.Categoria"></label>
            <select asp-for="Servico.Categoria" asp-items="Html.GetEnumSelectList<CategoriaServico>()"></select>
        </div>
        <button type="submit" class="btn-primario">Guardar</button>
        <a class="btn-secundario" href="/Servicos">Cancelar</a>
    </form>
</div>
